<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/surface">

        <!-- Row 1: logo + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◇"
                android:textColor="@color/accent"
                android:textSize="20sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIMIT"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_mono"
                android:textSize="20sp"
                android:letterSpacing="0.22" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="on-chain dex"
                android:textColor="@color/dim"
                android:textSize="10sp"
                android:fontFamily="@font/jetbrains_mono"
                android:letterSpacing="0.15"
                android:layout_marginStart="10dp" />

            <Button
                android:id="@+id/btnSound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="↻"
                android:textSize="12sp"
                android:textColor="@color/dim"
                android:background="@drawable/btn_ghost" />

            <View
                android:id="@+id/liveDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dot_live" />

            <TextView
                android:id="@+id/blockNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/dim"
                android:textSize="12sp"
                android:fontFamily="@font/jetbrains_mono" />

            <Button
                android:id="@+id/btnExit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="EXIT"
                android:textSize="11sp"
                android:textColor="@color/dim"
                android:background="@drawable/btn_ghost" />
        </LinearLayout>

        <!-- Row 2: wallet pills + bridge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/geckoPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_mono"
                android:textSize="13sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/pill" />

            <TextView
                android:id="@+id/balance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="— MINIMA · — USDT"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_mono"
                android:textSize="13sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/pill" />

            <TextView
                android:id="@+id/btnBridge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRIDGE USDT ↗"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_mono"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/pill_bridge" />
        </LinearLayout>
    </LinearLayout>

    <!-- header bottom border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/border" />

    <!-- Activity ticker -->
    <TextView
        android:id="@+id/ticker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:singleLine="true"
        android:ellipsize="end"
        android:textColor="@color/dim"
        android:textSize="12sp"
        android:fontFamily="@font/jetbrains_mono"
        android:text="Starting up…" />

    <!-- Pairing banner (hidden until needed) -->
    <TextView
        android:id="@+id/pairingBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:padding="12dp"
        android:text="Open Minima Core → Apps and enable Minima Limit, then return here."
        android:textColor="@color/white"
        android:background="@color/accent"
        android:textSize="12sp" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg"
        app:tabMode="scrollable"
        app:tabGravity="start"
        app:tabIndicatorColor="@color/accent"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="@color/accent"
        app:tabTextColor="@color/dim" />

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Footer -->
    <TextView
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="Limit v0.1.3  |  VERIFYOUT Smart Contract  |  Bridge USDT  |  GitHub"
        android:textColor="@color/dim"
        android:textSize="11sp"
        android:fontFamily="@font/jetbrains_mono"
        android:background="@color/bg" />
</LinearLayout>
